[
  {
    "name": "/reset without a name shows usage",
    "steps": [
      {
        "send": { "text": "/reset" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Usage: /reset <name>" } }
        ]
      }
    ]
  },
  {
    "name": "/reset with a non-existent counter shows error",
    "steps": [
      {
        "send": { "text": "/reset testcounter" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Counter not found." } }
        ]
      }
    ]
  }
]